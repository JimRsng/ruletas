    "type": "git",
    "url": "git+https://github.com/JimRsng/ruletas.git"
  },
  "bugs": "https://github.com/JimRsng/ruletas/issues",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --port=5173 --public",
    "generate": "nuxt generate",
    "preview": "wrangler d1 migrations apply DB --local && wrangler dev",
    "postinstall": "nuxt prepare",
    "analyze": "nuxt analyze",
    "db:migrate": "drizzle-kit generate --config=.config/drizzle.ts",
    "lint": "pnpm lint:eslint && pnpm lint:stylelint",
    "lint:fix": "pnpm lint:eslint --fix && pnpm lint:stylelint --fix",
    "lint:eslint": "eslint --config .config/eslint.mjs",
    "lint:eslint:inspect": "pnpx @eslint/config-inspector --config .config/eslint.mjs",
    "lint:stylelint": "stylelint \"**/*.{css,scss,sass}\" --config .config/stylelint.json",
    "test:types": "vue-tsc -b --noEmit"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/ui": "^4.5.1",
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/sitemap": "^7.6.0",
    "@pinia/nuxt": "^0.11.3",
    "@twurple/api": "^8.0.3",
    "@twurple/auth": "^8.0.3",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "howler": "^2.2.4",
    "nuxt": "^4.3.1",
    "nuxt-auth-utils": "^0.5.29",
    "pinia": "^3.0.4",
    "sass": "^1.97.3",
    "spin-wheel": "^5.0.2"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.96",
    "@iconify-json/simple-icons": "^1.2.72",
    "@nuxt/eslint": "^1.15.2",
    "@types/howler": "^2.2.12",
    "eslint": "^10.0.3",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.71.0"
  },
  "packageManager": "pnpm@10.31.0"
}
